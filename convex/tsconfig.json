{
	"compilerOptions": {
		"target": "ESNext",
		"lib": ["ES2021", "DOM"],
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"esModuleInterop": true,
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "react-jsx"
	},
	"include": ["./**/*.ts"],
	"exclude": ["./node_modules", "./_generated"]
}
