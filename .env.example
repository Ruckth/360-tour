# Convex
PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# Clerk (optional for demo launch; keep placeholder to disable auth UI)
PUBLIC_CLERK_PUBLISHABLE_KEY=placeholder

# Stripe (future production checkout only; current Vercel demo uses demo payment)
STRIPE_SECRET_KEY=sk_test_...
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Resend (for transactional emails)
RESEND_API_KEY=re_...

# AI Chat (OpenAI-compatible API)
AI_API_KEY=sk-...
AI_API_BASE_URL=https://api.openai.com/v1
AI_SIMPLE_MODEL=gpt-4o-mini
AI_COMPLEX_MODEL=gpt-4o

# Owner notification
OWNER_NOTIFICATION_EMAIL=owner@example.com
